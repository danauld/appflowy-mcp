# --- AppFlowy connection ---
# Base URL of AppFlowy-Cloud (no trailing slash).
APPFLOWY_BASE_URL=https://localhost

# Set to false only for self-signed certs in dev. true in production.
APPFLOWY_TLS_VERIFY=false

# Bot account used by the MCP server. Create via scripts/create-user.ps1
# (e.g. claude-bot@local). Share workspaces/pages with this account
# to make them visible through the MCP server.
APPFLOWY_BOT_EMAIL=claude-bot@local
APPFLOWY_BOT_PASSWORD=changeme

# --- MCP transport ---
# stdio: launched per-client (dev, Claude Code local)
# http : long-running server, streamable HTTP transport (prod, docker-compose)
APPFLOWY_MCP_TRANSPORT=stdio

# Only used when transport=http
APPFLOWY_MCP_HOST=0.0.0.0
APPFLOWY_MCP_PORT=8765
